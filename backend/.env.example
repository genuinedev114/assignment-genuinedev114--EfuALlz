# Leave blank to run extraction in offline stub mode (chat won't work without an OpenRouter key).
# Get a free OpenRouter key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=sqlite:///./invoices.db
UPLOAD_DIR=./uploads
# EXTRACTION_MODEL must support vision (image input).
# ASSISTANT_MODEL must support OpenAI-style tool/function calling.
# Free options (rate-limits vary, swap if you hit 429s):
#   Vision: nvidia/nemotron-nano-12b-v2-vl:free, google/gemma-4-31b-it:free
#   Tools:  openai/gpt-oss-120b:free, meta-llama/llama-3.3-70b-instruct:free,
#           qwen/qwen3-next-80b-a3b-instruct:free, z-ai/glm-4.5-air:free
EXTRACTION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
ASSISTANT_MODEL=openai/gpt-oss-120b:free
USE_STUB_EXTRACTION=0

# --- Auth ---
JWT_SECRET=dev-secret-change-me-in-prod
JWT_EXPIRY_SECONDS=604800
